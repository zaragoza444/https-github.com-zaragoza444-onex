# OneX Production Platform — copy to repo root .env on the VPS:
#   cp deploy/env.onexproduction.example .env

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_PRODUCTION_DOMAIN=onexproduction.com
ONEX_CORS_ORIGINS=https://onexproduction.com,https://www.onexproduction.com,https://git.anakatech.llc,https://zaragoza444.github.io,https://zaragoza444.github.io/onex
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.example.json
ONEX_PROJECT_ROOT=/opt/onex
