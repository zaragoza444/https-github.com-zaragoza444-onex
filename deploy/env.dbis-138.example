# IDBIS / DBIS Chain 138 — deploy env (copy to /etc/onex/onex.env on chain 138 server)

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.example.json
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=:9338

# Default ledger bridge target: DeFi Oracle Meta / SMOM-DBIS-138
ONEX_DEFAULT_BRIDGE_CHAIN=dbis-138
DBIS138_RPC_URL=https://rpc-core.d-bis.org
DBIS138_EXPLORER=https://explorer.d-bis.org
DBIS138_CHAIN_ID=138

# EVM holder (read balances) + sender key (settle ledger → chain 138)
# ONEX_EVM_HOLDER=0xYourDBIS138Address
# ONEX_EVM_SENDER_KEY=64hexPrivateKeyWithETHOnChain138

ONEX_CORS_ORIGINS=http://127.0.0.1:9338,https://explorer.d-bis.org,https://git.anakatech.llc,https://zaragoza444.github.io
