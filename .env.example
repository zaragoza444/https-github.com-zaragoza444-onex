ONEX_CASHCODE_ENABLED=1
ONEX_CASHCODE_TTL_HOURS=72   # optional, default 72h
ONEX_FAUCET_PRIVATE_KEY=
# Issue
Invoke-RestMethod -Method POST http://127.0.0.1:9338/bridge/cashcode/issue -ContentType application/json -Body '{"fromAccount":"nsb-operating","amount":"25.00","pin":"1234"}'

# Redeem
Invoke-RestMethod -Method POST http://127.0.0.1:9338/bridge/cashcode/redeem -ContentType application/json -Body '{"code":"XXXX-XXXX-XXXX","pin":"1234","toAccount":"nsb-reserve"}'Invoke-RestMethod -Method POST http://127.0.0.1:9338/bridge/cards/activate
Invoke-RestMethod http://127.0.0.1:9338/bridge/cards

# Optional API key for POST /api/v1/tx, /rpc, and bridge write endpoints (deploy, wrap, send).
# Set the same value in the wallet Settings when using a remote bridge (Gitea Pages).
ONEX_API_KEY=

# CORS origins (comma-separated) for browser wallet
ONEX_CORS_ORIGINS=http://localhost:8545,http://127.0.0.1:9338,https://git.anakatech.llc,https://zblockchainsystem.com

# Bridge (Docker / systemd — optional overrides)
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=:9338
ONEX_WALLET_PATH=
ONEX_PROJECT_ROOT=

# Real Ledger middleware (production = real bank/on-chain only, no simulated portfolio)
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.example.json

# Bridge7 — local-ledger-2026 + ledger-pro + crypto-ledger
# Default paths load from configs/bridge7.paths.json; env vars override the JSON file.
ONEX_BRIDGE7_ENABLED=1
ONEX_BRIDGE7_PATHS_FILE=configs/bridge7.paths.json

# Cash codes — one-time pickup codes via NSB escrow
ONEX_CASHCODE_ENABLED=1
# ONEX_CASHCODE_TTL_HOURS=72
# ONEX_LOCAL_LEDGER_2026_FILE=data/bridge7/local-ledger-2026.json
# ONEX_LEDGER_PRO_FILE=data/bridge7/ledger-pro.json
# ONEX_CRYPTO_LEDGER_FILE=data/bridge7/crypto-ledger.json
# ONEX_PROJECT_ROOT=/opt/onex
# ONEX_BANK_PROVIDER=plaid
# ONEX_PLAID_CLIENT_ID=
# ONEX_PLAID_SECRET=
# ONEX_PLAID_ACCESS_TOKEN=
# ONEX_EVM_HOLDER=0xYourEthereumAddress
# ONEX_EVM_SENDER_KEY=64hexPrivateKeyForLedgerToBSCBridge
# Leave ONEX_EVM_SENDER_KEY unset to auto-generate ~/.onex/evm-sender.key on bridge start
# ONEX_EVM_NO_AUTO_KEY=1

# QuickNode Ethereum mainnet (OneX master wallet + RPC)
# ONEX_ETHEREUM_RPC=https://your-endpoint.ethereum-mainnet.quiknode.pro/your-token
# ONEX_QUICKNODE_API_KEY=QN_your_quicknode_api_key
# ONEX_ETHEREUM_MASTER_WALLET=0xYourMasterWallet
# GET  /bridge/ethereum/status
# POST /bridge/ethereum/transfer  {"to":"0x…","amount":"0.01","asset":"ETH"}

# Mobile app (Expo) — set in mobile/.env as EXPO_PUBLIC_WALLET_URL
# EXPO_PUBLIC_WALLET_URL=https://zblockchainsystem.com/wallet/

# OneX AI (OpenAI-compatible: OpenAI, Azure, local LM Studio, etc.)
ONEX_AI_ENABLED=true
ONEX_AI_API_KEY=
ONEX_AI_BASE_URL=https://api.openai.com/v1
ONEX_AI_MODEL=gpt-4o-mini
