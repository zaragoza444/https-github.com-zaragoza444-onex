# =============================================================================
# OneX Production — LIVE payment gateway (copy to VPS, never commit)
# =============================================================================
# Docker:  cp deploy/env.production.live.example .env
# systemd: sudo cp deploy/env.production.live.example /etc/onex/onex.env
#
# Replace every CHANGE_ME / sk_live_ / pk_live_ / whsec_ value before go-live.
# Primary domain: zblockchainsystem.com
# GitHub: zaragoza444 | Gitea: Zaragoza @ git.anakatech.llc
# =============================================================================

# --- Core ---
ONEX_LEDGER_MODE=production
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_HOME_DIR=/home/ubuntu/.onex
ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=0.0.0.0:9338

# --- Domain & CORS ---
ONEX_PRODUCTION_DOMAIN=zblockchainsystem.com
ONEX_CORS_ORIGINS=https://zblockchainsystem.com,https://www.zblockchainsystem.com,https://blockchainsystem.com,https://www.blockchainsystem.com,http://blockchainsystem.com,http://www.blockchainsystem.com,https://git.anakatech.llc,https://zaragoza444.github.io,https://zaragoza444.github.io/onex

# --- Z Bank Online (canonical domain: zblockchainsystem.com) ---
ONEX_ONLINE_BANK=1
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.zbank.production.json

# --- Payment Gateway (Visa / Mastercard / Amex) ---
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.zbank.production.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=zbank
ONEX_PAYMENT_GATEWAY_PROVIDER=stripe

# Stripe LIVE keys — from https://dashboard.stripe.com/apikeys
ONEX_STRIPE_SECRET_KEY=sk_live_CHANGE_ME
ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret
ONEX_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Bridge7 / HYBX / Fineract (existing production stack) ---
ONEX_BRIDGE7_ENABLED=1
ONEX_BRIDGE7_PATHS_FILE=configs/bridge7.paths.json
ONEX_HYBX_ENABLED=1
ONEX_HYBX_URL=https://api.hybrix.io
ONEX_FINERACT_ENABLED=1
ONEX_FINERACT_URL=https://fineract.hybxfinance.com/fineract-provider
ONEX_FINERACT_TENANT=default
ONEX_FINERACT_USERNAME=CHANGE_ME
ONEX_FINERACT_PASSWORD=CHANGE_ME
ONEX_CASHCODE_ENABLED=1
ONEX_DEFAULT_BRIDGE_CHAIN=dbis-138
DBIS138_RPC_URL=https://rpc-core.d-bis.org
DBIS138_EXPLORER=https://explorer.d-bis.org
DBIS138_CHAIN_ID=138
