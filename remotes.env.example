# Copy remotes.env.example → remotes.env and set your Gitea git URL.
# Used by scripts/publish-production.ps1 and scripts/push-now.ps1

GITHUB_USER=zaragoza444
REPO_NAME=shiva-blockchain

# Example: https://gitea.com/zaragoza444/shiva-blockchain.git
GITEA_URL=

# Public bridge (Render) — also set GitHub variable SHIVA_BRIDGE_PUBLIC_URL
SHIVA_BRIDGE_PUBLIC_URL=
