# Nova 1 Chain 22016 — deploy env
# Copy to /etc/onex/onex.env on the bridge server (never commit live keys):
#   cp deploy/env.nova-1-22016.example /etc/onex/onex.env

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.nova.example.json
ONEX_ONLINE_BANK=1
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=:9338

# Default ledger bridge target: Nova 1 Chain
ONEX_DEFAULT_BRIDGE_CHAIN=nova-1
NOVA1_RPC_URL=https://rpc.nova1.chain
NOVA1_EXPLORER=https://explorer.nova1.chain
NOVA1_CHAIN_ID=22016

# EVM holder (read balances) + sender key (settle ledger → Nova 1)
# ONEX_EVM_HOLDER=0xYourNova1Address
# ONEX_EVM_SENDER_KEY=64hexPrivateKeyWithNOVAForGas

# HYBX + Fineract (Nova Bank Online)
ONEX_HYBX_ENABLED=1
ONEX_HYBX_URL=https://api.hybrix.io
ONEX_FINERACT_ENABLED=1
ONEX_FINERACT_URL=https://fineract.hybxfinance.com/fineract-provider
ONEX_FINERACT_TENANT=default
ONEX_FINERACT_USERNAME=CHANGE_ME
ONEX_FINERACT_PASSWORD=CHANGE_ME

ONEX_CORS_ORIGINS=http://127.0.0.1:9338,https://novatrustee.digital,https://onexproduction.com,https://git.anakatech.llc

# Payment Gateway (Visa / Mastercard / Amex)
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.example.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=nova
ONEX_PAYMENT_GATEWAY_PROVIDER=mock
# Production: set ONEX_PAYMENT_GATEWAY_PROVIDER=stripe and Stripe keys below
# ONEX_STRIPE_SECRET_KEY=sk_live_...
# ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_...
# ONEX_STRIPE_WEBHOOK_SECRET=whsec_...
