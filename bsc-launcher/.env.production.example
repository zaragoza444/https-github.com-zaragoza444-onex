# Production — copy to bsc-launcher/.env before docker compose up
BSC_LAUNCHER_ENV=production

# Required in production
BSC_LAUNCHER_API_KEY=change-me-to-long-random-secret
BSC_LAUNCHER_CORS_ORIGINS=https://tokens.yourdomain.com

# Listen (inside container)
BSC_LAUNCHER_LISTEN=:9340
BSC_LAUNCHER_DATA_DIR=/data
BSC_LAUNCHER_ROOT=/app/bsc-launcher
BSC_LAUNCHER_CONFIG_DIR=/app/configs

# Rate limit for POST endpoints (per IP per minute)
BSC_LAUNCHER_RATE_LIMIT=20

# BSC RPC + explorer
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_EXPLORER_URL=https://bscscan.com

# Etherscan API V2 (BSC chainid=56)
BSCSCAN_API_KEY=

# Optional: platform wallet deploy on BSC
BSC_DEPLOYER_PRIVATE_KEY=

# Flash Coin live CREATE2 deploy (all EVM chains)
FLASH_DEPLOYER_PRIVATE_KEY=

# Build stamp (set by CI)
# BSC_LAUNCHER_BUILD=2026.06.13
