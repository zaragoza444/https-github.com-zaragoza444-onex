# =============================================================================
# OneX Production — zblockchainsystem.com (LIVE)
# =============================================================================
# Docker:  cp deploy/env.zblockchainsystem.com.example .env
# systemd: sudo cp deploy/env.zblockchainsystem.com.example /etc/onex/onex.env
#
# Accounts:
#   GitHub: zaragoza444
#   Gitea:  Zaragoza  → https://git.anakatech.llc/Zaragoza/onex
# VPS:     51.75.64.28
# =============================================================================

ONEX_LEDGER_MODE=production
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_HOME_DIR=/home/ubuntu/.onex
ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=0.0.0.0:9338
ONEX_PUBLIC_HOST=51.75.64.28

# --- Domain & CORS ---
ONEX_PRODUCTION_DOMAIN=zblockchainsystem.com
ONEX_CORS_ORIGINS=https://zblockchainsystem.com,https://www.zblockchainsystem.com,https://blockchainsystem.com,https://git.anakatech.llc,https://zaragoza444.github.io,https://zaragoza444.github.io/onex,http://51.75.64.28:9338

# --- Z Bank Online + Payment Gateway (M1–M4) ---
ONEX_ONLINE_BANK=1
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.zbank.example.json
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.zbank.production.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=zbank
ONEX_PAYMENT_GATEWAY_PROVIDER=stripe

# Stripe LIVE — https://dashboard.stripe.com/apikeys
ONEX_STRIPE_SECRET_KEY=sk_live_CHANGE_ME
ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
ONEX_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Bridge7 / HYBX / Fineract ---
ONEX_BRIDGE7_ENABLED=1
ONEX_BRIDGE7_PATHS_FILE=configs/bridge7.paths.json
ONEX_HYBX_ENABLED=1
ONEX_HYBX_URL=https://api.hybrix.io
ONEX_FINERACT_ENABLED=1
ONEX_FINERACT_URL=https://fineract.hybxfinance.com/fineract-provider
ONEX_FINERACT_TENANT=default
ONEX_FINERACT_USERNAME=CHANGE_ME
ONEX_FINERACT_PASSWORD=CHANGE_ME
ONEX_CASHCODE_ENABLED=1
ONEX_DEFAULT_BRIDGE_CHAIN=dbis-138
DBIS138_RPC_URL=https://rpc-core.d-bis.org
DBIS138_EXPLORER=https://explorer.d-bis.org
DBIS138_CHAIN_ID=138

