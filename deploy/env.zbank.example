# Z Bank — deploy env
# Copy to /etc/onex/onex.env on the bridge server (never commit live keys):
#   cp deploy/env.zbank.example /etc/onex/onex.env
#
# Z Bank uses operational M1–M4 fund classes (spendable → safeguarded → treasury → wholesale).
# Do not point this host at Nova ledger/PG files. See docs/cis/CIS-Z-Bank-Online-v1.md.

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.zbank.example.json
ONEX_ONLINE_BANK=1
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=:9338

# Payment Gateway — Visa / Mastercard / Amex (Z Bank framework)
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.zbank.example.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=zbank
ONEX_PAYMENT_GATEWAY_PROVIDER=mock
# Production (zblockchainsystem.com): use payment-gateway.zbank.production.json + provider=stripe
# ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.zbank.production.json
# ONEX_PAYMENT_GATEWAY_PROVIDER=stripe
# ONEX_STRIPE_SECRET_KEY=sk_live_...
# ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_...
# ONEX_STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: HYBX + Fineract (shared middleware; brand is still Z Bank via ledger/PG)
# ONEX_HYBX_ENABLED=1
# ONEX_HYBX_URL=https://api.hybrix.io
# ONEX_FINERACT_ENABLED=1
# ONEX_FINERACT_URL=https://fineract.hybxfinance.com/fineract-provider
# ONEX_FINERACT_TENANT=default
# ONEX_FINERACT_USERNAME=CHANGE_ME
# ONEX_FINERACT_PASSWORD=CHANGE_ME

ONEX_CORS_ORIGINS=http://127.0.0.1:9338,https://onexproduction.com,https://git.anakatech.llc
