# Z Bank — deploy env (prefer full production template)
# Full production secrets template:
#   cp deploy/env.zbank.production.example /etc/onex/onex.env
#
# Z Bank M1–M4 + DSSBOaT officer (PIN + signature). No demo credentials in code.

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_LEDGER_MODE=production
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.zbank.production.json
ONEX_ONLINE_BANK=1
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_NODE_URL=http://127.0.0.1:8545
ONEX_BRIDGE_LISTEN=:9338

# Payment Gateway — production Stripe (Z Bank)
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.zbank.production.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=zbank
ONEX_PAYMENT_GATEWAY_PROVIDER=stripe
ONEX_STRIPE_SECRET_KEY=sk_live_CHANGE_ME
ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
ONEX_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# DSSBOaT corporate officer — REQUIRED for production seed (no demo defaults)
ONEX_ZBANK_OFFICERS_FILE=configs/zbank-officers.dssboat.example.json
ONEX_ZBANK_OFFICER_PIN=CHANGE_ME_4_TO_8_DIGITS
ONEX_ZBANK_OFFICER_SIGNATURE=CHANGE_ME_MIN_8_CHARS

ONEX_PRODUCTION_DOMAIN=zblockchainsystem.com
ONEX_CORS_ORIGINS=http://127.0.0.1:9338,https://zblockchainsystem.com,https://www.zblockchainsystem.com,https://git.anakatech.llc
