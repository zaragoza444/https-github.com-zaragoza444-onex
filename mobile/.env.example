# PouchPay Plus public wallet URL loaded in the WebView (must be HTTPS in production)
# Anakatech Gitea Pages (UI — set bridge URL in wallet Settings or ONEX_BRIDGE_PUBLIC_URL)
EXPO_PUBLIC_WALLET_URL=https://git.anakatech.llc/pages/zaragoza/onex/wallet/
EXPO_PUBLIC_APP_NAME=PouchPay Plus
EXPO_PUBLIC_POUCHPAY_URL=https://pouchpay.io/
EXPO_PUBLIC_ALLTRA_PLUS_RPC_URL=https://mainnet-rpc.alltra.global/
EXPO_PUBLIC_ALLTRA_PLUS_EXPLORER_URL=https://alltra.global/

# Or your own domain with full stack (recommended for production)
# EXPO_PUBLIC_WALLET_URL=https://your-pouchpay-plus-domain.com/wallet/

# Local dev (Android emulator → host machine)
# EXPO_PUBLIC_WALLET_URL=http://10.0.2.2:9338/wallet/
