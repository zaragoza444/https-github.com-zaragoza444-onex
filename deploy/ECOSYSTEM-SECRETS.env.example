# Astra ↔ OneX linked-systems secrets (LOCAL ONLY)
# Copy to deploy/ECOSYSTEM-SECRETS.env and fill real values.
# deploy/ECOSYSTEM-SECRETS.env is gitignored — never commit it.

# ═══ AnakaBank ═══
ANAKABANK_ADMIN_EMAIL=CHANGE_ME
ANAKABANK_ADMIN_PASSWORD=CHANGE_ME

# ═══ NovaBank (Railway instance) ═══
NOVABANK_RAILWAY_EMAIL=CHANGE_ME
NOVABANK_RAILWAY_PIN=CHANGE_ME
NOVABANK_RAILWAY_URL=CHANGE_ME

# ═══ NovaBank (VPS instance on OneX host) ═══
NOVABANK_VPS_EMAIL=CHANGE_ME
NOVABANK_VPS_PIN=CHANGE_ME
NOVABANK_VPS_HOST=51.75.64.28
NOVABANK_VPS_PORT=3100

# ═══ Shared htpasswd (protected endpoints) ═══
HTPASSWD_USER=CHANGE_ME
HTPASSWD_PASSWORD=CHANGE_ME

# ═══ Iroha / AnakaBank gateway (CT59) ═══
IROHA_GATEWAY_API_KEY=CHANGE_ME
IROHA_TREASURY_ACCOUNT=CHANGE_ME
IROHA_DOMAIN=anakachain

# ═══ Astra SSH (optional; prefer key auth) ═══
