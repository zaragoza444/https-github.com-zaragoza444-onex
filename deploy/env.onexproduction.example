# OneX production environment — copy to .env on the VPS:
#   cp deploy/env.onexproduction.example .env

ONEX_LEDGER_MODE=production
ONEX_ONLINE_BANK=1
ONEX_NODE_OPTIONAL=1
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.example.json

# HYBX multi-ledger + exchange middleware
ONEX_HYBX_ENABLED=1
ONEX_HYBX_URL=https://api.hybrix.io

# Fineract core banking (hybxfinance.com)
ONEX_FINERACT_ENABLED=1
ONEX_FINERACT_URL=https://fineract.hybxfinance.com/fineract-provider
ONEX_FINERACT_TENANT=default
ONEX_FINERACT_USERNAME=CHANGE_ME
ONEX_FINERACT_PASSWORD=CHANGE_ME

# Bridge7 — local-ledger-2026 + ledger-pro + crypto-ledger
# Paths resolve from configs/bridge7.paths.json unless overridden below.
ONEX_BRIDGE7_ENABLED=1
ONEX_BRIDGE7_PATHS_FILE=configs/bridge7.paths.json
ONEX_PROJECT_ROOT=/opt/onex
# ONEX_LOCAL_LEDGER_2026_FILE=/opt/onex/data/bridge7/local-ledger-2026.json
# ONEX_LEDGER_PRO_FILE=/opt/onex/data/bridge7/ledger-pro.json
# ONEX_CRYPTO_LEDGER_FILE=/opt/onex/data/bridge7/crypto-ledger.json

# Cash codes + Cards 101.1 online (BIN 1011)
ONEX_CASHCODE_ENABLED=1

# Optional live EVM settlement (HYBX covers chain routes if unset)
# ONEX_EVM_SENDER_KEY=0x...
# DBIS138_RPC_URL=https://rpc-core.d-bis.org

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_PRODUCTION_DOMAIN=onexproduction.com
ONEX_CORS_ORIGINS=https://onexproduction.com,https://www.onexproduction.com,https://git.anakatech.llc,https://zaragoza444.github.io,https://zaragoza444.github.io/onex
