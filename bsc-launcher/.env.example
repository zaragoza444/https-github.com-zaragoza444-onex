# development | production
BSC_LAUNCHER_ENV=development

# BSC RPC endpoint (mainnet)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# API key for POST endpoints (required in production)
# BSC_LAUNCHER_API_KEY=

# CORS origins, comma-separated (production: your domain only)
# BSC_LAUNCHER_CORS_ORIGINS=https://tokens.example.com

# Required for "Platform wallet" deploy — fund this address with BNB for gas
BSC_DEPLOYER_PRIVATE_KEY=

# Etherscan API V2 key (works for BSC via chainid=56) — get free key at:
# https://etherscan.io/apidashboard  or https://bscscan.com/myapikey
BSCSCAN_API_KEY=
# ETHERSCAN_API_KEY=   # alternative name, same key

# Server listen address
BSC_LAUNCHER_LISTEN=:9340

# Token registry storage directory
BSC_LAUNCHER_DATA_DIR=./data

# Optional: override project root (auto-detected from exe location if unset)
BSC_LAUNCHER_ROOT=
