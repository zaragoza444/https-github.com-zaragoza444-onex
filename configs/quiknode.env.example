# QuickNode Ethereum mainnet — copy values into .env (never commit secrets)
ONEX_ETHEREUM_RPC=https://your-endpoint.ethereum-mainnet.quiknode.pro/your-rpc-token
ONEX_QUICKNODE_API_KEY=QN_your_api_key
ONEX_ETHEREUM_MASTER_WALLET=0xYourMasterWalletAddress
ONEX_EVM_HOLDER=0xYourMasterWalletAddress
# Required for live on-chain sends from master treasury (64 hex chars — NOT the wallet address):
# ONEX_ETHEREUM_MASTER_KEY=
# Or place key in ~/.onex/ethereum-master.key (chmod 600)
# POST /bridge/ethereum/fund-sender  — send gas from master → bridge sender
