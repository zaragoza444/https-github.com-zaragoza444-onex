CT59_SSH_PORT=22
CT59_SSH_USER=root
CT59_SSH_PASSWORD=CHANGE_ME

# ═══ NEED_FROM_Z (OneX / OVH VPS — fill from GitHub Secrets / OVH panel) ═══
