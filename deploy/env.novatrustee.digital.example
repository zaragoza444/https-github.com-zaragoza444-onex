# novatrustee.digital — production env (copy to .env on VPS)
# Use this if novatrustee.digital is your primary HTTPS domain.

ONEX_API_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ONEX_PRODUCTION_DOMAIN=novatrustee.digital
ONEX_CORS_ORIGINS=https://novatrustee.digital,https://onexproduction.com,https://git.anakatech.llc
ONEX_LEDGER_MODE=production
ONEX_PROJECT_ROOT=/home/ubuntu/onex
ONEX_HOME_DIR=/home/ubuntu/.onex
ONEX_ONLINE_BANK=1
ONEX_BANK_LEDGER_FILE=configs/bank-ledger.nova.example.json
ONEX_PAYMENT_GATEWAY=1
ONEX_PAYMENT_GATEWAY_FILE=configs/payment-gateway.production.json
ONEX_PAYMENT_GATEWAY_FRAMEWORK=nova
ONEX_PAYMENT_GATEWAY_PROVIDER=stripe
ONEX_STRIPE_SECRET_KEY=sk_live_CHANGE_ME
ONEX_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
ONEX_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
